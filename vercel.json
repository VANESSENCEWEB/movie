{
  "version": 2,
  "public": true,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/styles/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/scripts/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "rewrites": [
    { "source": "/informacoes", "destination": "/informacoes/index.html" },
    { "source": "/conheca-recife", "destination": "/conheca-recife/index.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/apartamentos/:slug", "destination": "/apartamentos/:slug.html" }
  ]
}
